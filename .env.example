NODE_ENV=development
APP_NAME=AresQuant
APP_PORT=3000
LOG_LEVEL=info

DATABASE_URL=postgresql://ares_quant:ares_quant_password@localhost:5432/ares_quant?schema=public
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
POSTGRES_DB=ares_quant
POSTGRES_USER=ares_quant
POSTGRES_PASSWORD=ares_quant_password
POSTGRES_PORT=5432
REDIS_PORT=6379

DATA_SYNC_BATCH_SIZE=1000
DATA_SYNC_CONCURRENCY=5
DATA_SYNC_SOURCE=eastmoney
# mock | eastmoney. Eastmoney uses public web endpoints for research/backtest data and may be rate limited.
DATA_PROVIDER=eastmoney
DEFAULT_START_DATE=20100101
DEFAULT_END_DATE=
BACKTEST_DEFAULT_INITIAL_CASH=1000000
BACKTEST_DEFAULT_COMMISSION_RATE=0.0003
BACKTEST_DEFAULT_SLIPPAGE_RATE=0.0005

NODE_ENV=development
APP_NAME=AresQuant
APP_PORT=3000
LOG_LEVEL=info

DATABASE_URL=postgresql://ares_quant:ares_quant_password@localhost:5432/ares_quant?schema=public
REDIS_URL=redis://localhost:6379/0
POSTGRES_DB=ares_quant
POSTGRES_USER=ares_quant
POSTGRES_PASSWORD=ares_quant_password
POSTGRES_PORT=5432
REDIS_PORT=6379

DATA_SYNC_BATCH_SIZE=1000
DATA_SYNC_SOURCE=mock
BACKTEST_DEFAULT_INITIAL_CASH=1000000
BACKTEST_DEFAULT_COMMISSION_RATE=0.0003
BACKTEST_DEFAULT_SLIPPAGE_RATE=0.0005
